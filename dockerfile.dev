# ─────────────────────────────────────────────
# Etapa única: desarrollo con hot-reload (HMR)
# ─────────────────────────────────────────────
# Node 22 LTS Alpine — imagen mínima, compatible con Vite 8 + TS 5.9
FROM node:22-alpine

# Instalar dependencias del sistema que node-gyp puede necesitar
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copiar manifiestos de dependencias primero (aprovecha cache de capas)
COPY package.json package-lock.json ./

# Instalar todas las deps (incluyendo devDeps para dev)
# ci respeta package-lock.json exactamente
RUN npm ci

# No copiamos el source: viene montado como volumen en docker-compose.yml
# Esto permite que los cambios en el host se reflejen en tiempo real (HMR)

EXPOSE 5173

# Vite debe escuchar en 0.0.0.0 para ser accesible desde fuera del contenedor
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
